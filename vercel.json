{
  "version": 2,
  "builds": [
    {
      "src": "api/status.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "style.css",
      "use": "@vercel/static"
    },
    {
      "src": "fayas_avatar.png",
      "use": "@vercel/static"
    },
    {
      "src": "Fayas_Resume_v7.pdf",
      "use": "@vercel/static"
    },
    {
      "src": "robots.txt",
      "use": "@vercel/static"
    },
    {
      "src": "sitemap.xml",
      "use": "@vercel/static"
    },
    {
      "src": "README.md",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/status",
      "dest": "api/status.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
